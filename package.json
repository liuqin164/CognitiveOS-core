{
  "name": "cogmem",
  "version": "2.0.2",
  "type": "module",
  "description": "cogmem — agent-native memory kernel for a single local-first AI agent",
  "main": "./dist/public.js",
  "types": "./dist/public.d.ts",
  "exports": {
    ".": {
      "import": "./dist/public.js",
      "types": "./dist/public.d.ts"
    },
    "./internal": {
      "import": "./dist/internal.js",
      "types": "./dist/internal.d.ts"
    }
  },
  "bin": {
    "cogmem": "dist/bin/cogmem.js",
    "cogmem-init": "dist/bin/init.js",
    "cogmem-doctor": "dist/bin/doctor.js",
    "cogmem-connect": "dist/bin/connect.js",
    "cogmem-update": "dist/bin/update.js",
    "cogmem-compact": "dist/bin/compact.js",
    "cogmem-memory": "dist/bin/memory.js",
    "cogmem-explain-recall": "dist/bin/explain-recall.js",
    "cogmem-mcp": "dist/bin/mcp.js",
    "cogmem-import-openclaw": "dist/bin/import-openclaw.js",
    "cogmem-import-hermes": "dist/bin/import-hermes.js",
    "cogmem-normalize-transcript": "dist/bin/normalize-transcript.js",
    "cogmem-snapshot": "dist/bin/snapshot.js",
    "cogmem-re-embed": "dist/bin/re-embed.js",
    "cogmem-migrate-vectors": "dist/bin/migrate-vectors.js"
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.json",
    "prepare": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.json",
    "type": "tsc -p tsconfig.json --noEmit",
    "test": "bun test __tests__",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@xenova/transformers": "^2.17.2",
    "hnswlib-node": "^2.0.1",
    "mammoth": "^1.12.0",
    "pdfjs-dist": "^6.0.227",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "bun-types": "^1.0.0",
    "typescript": "^5.4.0"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "examples/**/*.md",
    "install.sh",
    "README.md",
    "MEMORY_MODEL.md",
    "RECALL_EXPLAINABILITY.md",
    "BENCHMARKS.md",
    "CHANGELOG.md",
    "CONCURRENT_ACCESS.md",
    "CONTRIBUTING.md",
    "RELEASE_CHECKLIST.md",
    "SECURITY.md",
    "LICENSE"
  ],
  "license": "MIT"
}
