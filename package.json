{
  "name": "@CognitiveOS/core",
  "version": "2.0.0-rc.1",
  "type": "module",
  "description": "CognitiveOS Memory Kernel — durable, governed, topic-aware memory backend for AI agents",
  "main": "./dist/public.js",
  "types": "./dist/public.d.ts",
  "exports": {
    ".": {
      "import": "./dist/public.js",
      "types": "./dist/public.d.ts"
    },
    "./internal": {
      "import": "./dist/internal.js",
      "types": "./dist/internal.d.ts"
    }
  },
  "bin": {
    "cogmem-init": "dist/bin/init.js",
    "cogmem-doctor": "dist/bin/doctor.js",
    "cogmem-import-openclaw": "dist/bin/import-openclaw.js",
    "cogmem-import-hermes": "dist/bin/import-hermes.js",
    "cogmem-snapshot": "dist/bin/snapshot.js",
    "cogmem-re-embed": "dist/bin/re-embed.js",
    "cogmem-migrate-vectors": "dist/bin/migrate-vectors.js"
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.json",
    "prepare": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "hnswlib-node": "^2.0.1"
  },
  "devDependencies": {
    "bun-types": "^1.0.0",
    "typescript": "^5.4.0"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "examples/**/*.md",
    "README.md",
    "CHANGELOG.md",
    "CONCURRENT_ACCESS.md",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "LICENSE"
  ],
  "license": "MIT"
}
